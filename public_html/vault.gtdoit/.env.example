# ── Vault environment — mall ────────────────────────────────────────
# Kopiera denna fil till .env och fyll i dina riktiga värden.
# .env skyddas av .htaccess och finns ej i git.

# Database (Hetzner managed)
DB_HOST=your-db-host.your-database.de
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password
DB_SSL=true

# Auth — generera en lång slumpmässig sträng (min 32 tecken)
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
JWT_EXPIRY_DAYS=30

# Uploads
UPLOAD_URL=/uploads/
MAX_UPLOAD_MB=10

# Mail (SMTP)
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=Vault

# App
APP_URL=https://vault.gtdoit.com
ADMIN_EMAIL=admin@gtdoit.com
